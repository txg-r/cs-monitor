{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FastAPI (AI Path)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "LOG_LEVEL": "DEBUG",
        "SCHEDULER_ENABLED": "false"
      },
      "console": "integratedTerminal",
      "justMyCode": true,
      "jinja": true
    },
    {
      "name": "Debug Rebuild Events (AI Reanalyze)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.rebuild_events",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "LOG_LEVEL": "DEBUG"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Debug Rebuild Events (Reuse Analysis)",
      "type": "debugpy",
      "request": "launch",
      "module": "app.rebuild_events",
      "args": [
        "--reuse-analysis"
      ],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "LOG_LEVEL": "DEBUG"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
