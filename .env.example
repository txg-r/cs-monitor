DATABASE_URL=postgresql+psycopg://cs_monitor:change-me@db:5432/cs_monitor
POSTGRES_PASSWORD=change-me
LOG_LEVEL=DEBUG
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log
SCHEDULER_ENABLED=true
ADMIN_TOKEN=replace-with-a-long-random-token
CONTACT_EMAIL=you@example.com

# OpenAI 兼容接口；关闭时自动使用低置信度规则分析。
AI_ENABLED=false
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4.1-mini

FEISHU_WEBHOOK_URL=
FEISHU_SECRET=
FEISHU_STARTUP_CHECK_ENABLED=true

# Liquipedia 需要可识别的 User-Agent，因此还必须配置 CONTACT_EMAIL。
LIQUIPEDIA_ENABLED=false
YOUTUBE_CHANNEL_IDS=

# 仅在已获得 Reddit API 权限后填写。
REDDIT_SUBREDDITS=csgomarketforum,GlobalOffensive
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
